# Domain
# This would be set to the production domain with an env var on deployment
# used by Traefik to transmit traffic and acquire TLS certificates
DOMAIN=localhost

# Environment: local, staging, production
ENVIRONMENT=local

PROJECT_NAME="Multi-Tenant Organization Manager"
STACK_NAME=multi-tenant-org-manager

# Backend
BACKEND_CORS_ORIGINS="http://localhost,http://localhost:8000"
SECRET_KEY=PP2Mgh7am95NrKVFZektonezy1XtOHvZ8yqSjGd-anU
FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=changethis

# Used by the backend to generate links in password-reset emails
FRONTEND_HOST=http://localhost:8000

# Emails
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
EMAILS_FROM_EMAIL=info@example.com
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# Postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changethis

SENTRY_DSN=

# LLM (optional — required only for the /audit-logs/ask chatbot endpoint)
LLM_API_KEY=
LLM_PROVIDER=gemini

# Docker image name for the backend service
DOCKER_IMAGE_BACKEND=backend
